# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs
ELEVENLABS_API_KEY=...

# ClickUp (your personal API token — get it from clickup.com/api)
CLICKUP_API_KEY=...
# The workspace/team ID visible in your ClickUp URL: app.clickup.com/XXXXXXXXX/...
CLICKUP_TEAM_ID=...

# ClickUp numeric user IDs — used to assign tasks to the right person
# Find yours: ClickUp → Settings → My Profile, or use the API: GET /api/v2/user
CLICKUP_USER_ID_SANYUJA=...
CLICKUP_USER_ID_ALFRED=...
CLICKUP_USER_ID_MISS_BEHAVE=...

# Port
PORT=3001
